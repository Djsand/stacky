+ *
+ * SPDX-License-Identifier: MIT
+ */
+#include "app_stacky.h"
+
+#include <assets/assets.h>
+#include <hal/hal.h>
+#include <hal/stacky_bridge.h>
+#include <mooncake_log.h>
+#include <smooth_lvgl.hpp>
+#include <stackchan/avatar/skins/default/default.h>
+#include <stackchan/stackchan.h>
+
+using namespace mooncake;
+using namespace smooth_ui_toolkit::lvgl_cpp;
+using namespace stackchan;
+
+AppStacky::AppStacky()
+{
+    setAppInfo().name = "STACKY";
+    static auto icon  = assets::get_image("icon_ai_agent.bin");
+    setAppInfo().icon = (void*)&icon;
+    static uint32_t theme_color = 0x33CC99;
+    setAppInfo().userData       = (void*)&theme_color;
+}
+
+void AppStacky::onCreate()
+{
+    mclog::tagInfo(getAppInfo().name, "on create");
+}
+
+void AppStacky::onOpen()
+{
+    mclog::tagInfo(getAppInfo().name, "on open");
+    _is_open = true;
+    create_avatar();
+    GetStackyBridge().start();
+}
+
+void AppStacky::onRunning()
+{
+    if (!_is_open) {
+        return;
+    }
+
+    LvglLockGuard lock;
+    GetStackChan().update();
+}
+
+void AppStacky::onClose()
+{
+    mclog::tagInfo(getAppInfo().name, "on close");
+    _is_open = false;
+    GetStackyBridge().stop();
+
+    LvglLockGuard lock;
+    GetStackChan().clearModifiers();
+    GetStackChan().resetAvatar();
+}
+
+void AppStacky::create_avatar()
+{
+    LvglLockGuard lock;
+
+    auto& stacky_body = GetStackChan();
+    stacky_body.clearModifiers();
+    stacky_body.resetAvatar();
+
+    auto avatar = std::make_unique<avatar::DefaultAvatar>();
+    avatar->init(lv_screen_active(), &lv_font_montserrat_20);
+    stacky_body.attachAvatar(std::move(avatar));
+    stacky_body.avatar().setEmotion(avatar::Emotion::Neutral);
+    stacky_body.avatar().setSpeech("Stacky");
+    stacky_body.addModifier(std::make_unique<BlinkModifier>());
+    stacky_body.addModifier(std::make_unique<BreathModifier>(0, 8, 7600, 700));
+    stacky_body.addModifier(std::make_unique<IdleExpressionModifier>(3500, 9000));
+}
