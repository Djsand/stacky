@@ -0,0 +1,967 @@
+#include "stacky_bridge.h"
+
+#include "hal.h"
+#include "hal/board/config.h"
+#include "hal/board/hal_bridge.h"
+#include "utils/wifi_connect/wifi_station.h"
+
+#include <ArduinoJson.h>
+#include <audio/audio_codec.h>
+#include <board.h>
+#include <esp_heap_caps.h>
+#include <esp_log.h>
+#include <esp_timer.h>
+#include <freertos/FreeRTOS.h>
+#include <freertos/semphr.h>
+#include <freertos/task.h>
+#include <jpg/image_to_jpeg.h>
+#include <lwip/errno.h>
+#include <lwip/inet.h>
+#include <lwip/netdb.h>
+#include <lwip/sockets.h>
+#include <mbedtls/base64.h>
+#include <smooth_lvgl.hpp>
+#include <stackchan/modifiers/modifiers.h>
+#include <stackchan/stackchan.h>
+
+#include <algorithm>
+#include <atomic>
+#include <cmath>
+#include <cstdlib>
+#include <cstring>
+#include <memory>
+#include <string>
+#include <vector>
+
+#if __has_include("stacky_local_config.h")
+#include "stacky_local_config.h"
+#elif __has_include("../../../../../firmware/stacky_cores3/include/wifi_secrets.h")
+#include "../../../../../firmware/stacky_cores3/include/wifi_secrets.h"
+#endif
+
+#ifndef STACKY_WIFI_SSID
+#ifdef WIFI_SSID
+#define STACKY_WIFI_SSID WIFI_SSID
+#else
+#define STACKY_WIFI_SSID ""
+#endif
+#endif
+
+#ifndef STACKY_WIFI_PASSWORD
+#ifdef WIFI_PASSWORD
+#define STACKY_WIFI_PASSWORD WIFI_PASSWORD
+#else
+#define STACKY_WIFI_PASSWORD ""
+#endif
+#endif
+
+#ifndef STACKY_HOST
+#define STACKY_HOST ""
+#endif
+
+#ifndef STACKY_PORT
+#define STACKY_PORT 8765
+#endif
+
+namespace {
+
+constexpr const char* TAG = "StackyBridge";
+constexpr const char* STACKY_BRIDGE_VERSION = "official-0.1.14";
+constexpr size_t MIC_FRAME_COUNT = 480;       // 20 ms at 24 kHz
+constexpr int MIC_WARMUP_DISCARD_FRAMES = 12;
+constexpr size_t PLAYBACK_CHUNK_SAMPLES = 960;
+constexpr size_t STACKY_MAX_VISION_JPEG_BYTES = 160 * 1024;
+constexpr double TWO_PI = 6.2831853071795864769;
+constexpr int STACKY_MIC_INPUT_GAIN = 75;
+constexpr int STACKY_OUTPUT_VOLUME = 100;
+constexpr int STACKY_CENTER_YAW = 90;
+constexpr int STACKY_CENTER_PITCH = 260;
+constexpr int STACKY_LOOK_YAW_RANGE = 720;
+constexpr int STACKY_LOOK_UP_RANGE = 520;
+constexpr int STACKY_LOOK_DOWN_RANGE = 220;
+constexpr int STACKY_MIN_PITCH = 30;
+constexpr int STACKY_MAX_PITCH = 870;
+
+double now_seconds()
+{
+    return static_cast<double>(esp_timer_get_time()) / 1000000.0;
+}
+
+bool config_available()
+{
+    return std::strlen(STACKY_WIFI_SSID) > 0 && std::strlen(STACKY_HOST) > 0;
+}
+
+bool base64_encode(const uint8_t* data, size_t size, std::string& output)
+{
+    if (!data || size == 0) {
+        return false;
+    }
+
+    const size_t max_output_size = ((size + 2) / 3) * 4;
+    output.assign(max_output_size + 1, '\0');
+
+    size_t output_size = 0;
+    const int rc       = mbedtls_base64_encode(
+        reinterpret_cast<unsigned char*>(&output[0]),
+        output.size(),
+        &output_size,
+        reinterpret_cast<const unsigned char*>(data),
+        size);
+    if (rc != 0) {
+        output.clear();
+        return false;
+    }
+    output.resize(output_size);
+    return true;
+}
+
+}  // namespace
+
+class StackyBridgeImpl : public StackyBridge {
+public:
+    void start() override
+    {
+        enabled_.store(true);
+        if (started_.exchange(true)) {
+            return;
+        }
+        send_mutex_  = xSemaphoreCreateMutex();
+        audio_mutex_ = xSemaphoreCreateMutex();
+        xTaskCreatePinnedToCore(&StackyBridgeImpl::mainTaskThunk, "stacky_bridge", 8192, this, 4, nullptr, 0);
+        xTaskCreatePinnedToCore(&StackyBridgeImpl::micTaskThunk, "stacky_mic", 8192, this, 5, nullptr, 1);
+    }
+
+    void stop() override
+    {
+        enabled_.store(false);
+        connected_.store(false);
+        audio_hold_.store(true);
+        playback_active_.store(false);
+        closeSocket();
+
+        auto* codec = Board::GetInstance().GetAudioCodec();
+        if (codec && audio_mutex_) {
+            xSemaphoreTake(audio_mutex_, portMAX_DELAY);
+            if (codec->input_enabled()) {
+                codec->EnableInput(false);
+            }
+            if (codec->output_enabled()) {
+                codec->EnableOutput(false);
+            }
+            xSemaphoreGive(audio_mutex_);
+        }
+    }
+
+private:
+    std::atomic<bool> started_{false};
+    std::atomic<bool> enabled_{false};
+    std::atomic<bool> connected_{false};
+    std::atomic<bool> audio_hold_{false};
+    std::atomic<bool> playback_active_{false};
+    SemaphoreHandle_t send_mutex_  = nullptr;
+    SemaphoreHandle_t audio_mutex_ = nullptr;
+    std::unique_ptr<StackChanWifiStation> wifi_;
+    int socket_ = -1;
+    std::string rx_line_;
+    std::vector<int16_t> playback_samples_;
+    int playback_sample_rate_ = AUDIO_OUTPUT_SAMPLE_RATE;
+    int playback_channels_    = 1;
+    std::atomic<int> output_volume_{STACKY_OUTPUT_VOLUME};
+    std::atomic<int> input_gain_{STACKY_MIC_INPUT_GAIN};
+    std::atomic<int> display_brightness_{80};
+    std::atomic<int> center_yaw_{STACKY_CENTER_YAW};
+    std::atomic<int> center_pitch_{STACKY_CENTER_PITCH};
+    std::atomic<int> look_yaw_range_{STACKY_LOOK_YAW_RANGE};
+    std::atomic<int> look_up_range_{STACKY_LOOK_UP_RANGE};
+    std::atomic<int> look_down_range_{STACKY_LOOK_DOWN_RANGE};
+
+    static void mainTaskThunk(void* arg)
+    {
+        static_cast<StackyBridgeImpl*>(arg)->mainTask();
+    }
+
+    static void micTaskThunk(void* arg)
+    {
+        static_cast<StackyBridgeImpl*>(arg)->micTask();
+    }
+
+    void mainTask()
+    {
+        ESP_LOGI(TAG, "Stacky bridge starting: host=%s port=%d", STACKY_HOST, STACKY_PORT);
+
+        while (true) {
+            if (!enabled_.load()) {
+                vTaskDelay(pdMS_TO_TICKS(200));
+                continue;
+            }
+            if (!config_available()) {
+                ESP_LOGW(TAG, "Stacky bridge disabled: missing WiFi or host config");
+                vTaskDelay(pdMS_TO_TICKS(3000));
+                continue;
+            }
+            if (!ensureWifi()) {
+                vTaskDelay(pdMS_TO_TICKS(3000));
+                continue;
+            }
+            if (!connectToStacky()) {
+                vTaskDelay(pdMS_TO_TICKS(1500));
+                continue;
+            }
+
+            connected_.store(true);
+            sendStatus("connected");
+            commandLoop();
+            connected_.store(false);
+            audio_hold_.store(false);
+            playback_active_.store(false);
+            closeSocket();
+            vTaskDelay(pdMS_TO_TICKS(1200));
+        }
+    }
+
+    bool ensureWifi()
+    {
+        if (!wifi_) {
+            wifi_ = std::make_unique<StackChanWifiStation>();
+            wifi_->OnConnected([](const std::string& ssid) { ESP_LOGI(TAG, "WiFi connected: %s", ssid.c_str()); });
+            wifi_->OnConnectFailed([](const std::string& ssid) { ESP_LOGW(TAG, "WiFi connect failed: %s", ssid.c_str()); });
+            wifi_->Start();
+            wifi_->SetPowerSaveMode(false);
+        }
+
+        if (wifi_->IsConnected()) {
+            return true;
+        }
+
+        ESP_LOGI(TAG, "Connecting WiFi SSID=%s", STACKY_WIFI_SSID);
+        wifi_->AddAuth(STACKY_WIFI_SSID, STACKY_WIFI_PASSWORD);
+        return wifi_->WaitForConnected(15000);
+    }
+
+    bool connectToStacky()
+    {
+        struct sockaddr_in dest = {};
+        dest.sin_family         = AF_INET;
+        dest.sin_port           = htons(STACKY_PORT);
+        if (inet_pton(AF_INET, STACKY_HOST, &dest.sin_addr) != 1) {
+            ESP_LOGE(TAG, "Invalid Stacky host: %s", STACKY_HOST);
+            return false;
+        }
+
+        int sock = socket(AF_INET, SOCK_STREAM, IPPROTO_IP);
+        if (sock < 0) {
+            ESP_LOGE(TAG, "socket() failed errno=%d", errno);
+            return false;
+        }
+
+        timeval timeout = {};
+        timeout.tv_sec  = 0;
+        timeout.tv_usec = 120000;
+        setsockopt(sock, SOL_SOCKET, SO_RCVTIMEO, &timeout, sizeof(timeout));
+
+        ESP_LOGI(TAG, "Connecting Stacky at %s:%d", STACKY_HOST, STACKY_PORT);
+        if (connect(sock, reinterpret_cast<sockaddr*>(&dest), sizeof(dest)) != 0) {
+            ESP_LOGW(TAG, "Stacky connect failed errno=%d", errno);
+            close(sock);
+            return false;
+        }
+
+        xSemaphoreTake(send_mutex_, portMAX_DELAY);
+        socket_ = sock;
+        xSemaphoreGive(send_mutex_);
+        ESP_LOGI(TAG, "Stacky TCP connected");
+        return true;
+    }
+
+    void commandLoop()
+    {
+        while (enabled_.load() && connected_.load()) {
+            std::string line;
+            const ReadResult result = readLine(line);
+            if (result == ReadResult::Disconnected) {
+                break;
+            }
+            if (result == ReadResult::LineReady) {
+                handleCommand(line);
+            }
+        }
+    }
+
+    enum class ReadResult {
+        NoLine,
+        LineReady,
+        Disconnected,
+    };
+
+    ReadResult readLine(std::string& line)
+    {
+        char ch = 0;
+        int ret = recv(socket_, &ch, 1, 0);
+        if (ret == 1) {
+            if (ch == '\n') {
+                line.swap(rx_line_);
+                rx_line_.clear();
+                return ReadResult::LineReady;
+            }
+            if (rx_line_.size() < 4096) {
+                rx_line_.push_back(ch);
+            } else {
+                rx_line_.clear();
+            }
+            return ReadResult::NoLine;
+        }
+        if (ret == 0) {
+            return ReadResult::Disconnected;
+        }
+        if (errno == EAGAIN || errno == EWOULDBLOCK) {
+            return ReadResult::NoLine;
+        }
+        ESP_LOGW(TAG, "recv failed errno=%d", errno);
+        return ReadResult::Disconnected;
+    }
+
+    bool recvExact(uint8_t* data, size_t size)
+    {
+        size_t offset = 0;
+        while (offset < size && connected_.load()) {
+            int ret = recv(socket_, data + offset, size - offset, 0);
+            if (ret > 0) {
+                offset += static_cast<size_t>(ret);
+                continue;
+            }
+            if (ret == 0) {
+                return false;
+            }
+            if (errno == EAGAIN || errno == EWOULDBLOCK) {
+                continue;
+            }
+            ESP_LOGW(TAG, "recvExact failed errno=%d", errno);
+            return false;
+        }
+        return offset == size;
+    }
+
+    void handleCommand(const std::string& line)
+    {
+        JsonDocument doc;
+        auto err = deserializeJson(doc, line);
+        if (err) {
+            ESP_LOGW(TAG, "bad json command: %s", err.c_str());
+            return;
+        }
+
+        const char* type = doc["type"] | "";
+        JsonVariantConst payload = doc["payload"];
+
+        if (std::strcmp(type, "audio.hold") == 0) {
+            audio_hold_.store(payload["active"] | false);
+            return;
+        }
+        if (std::strcmp(type, "audio.start") == 0) {
+            playback_samples_.clear();
+            playback_sample_rate_ = payload["sampleRate"] | AUDIO_OUTPUT_SAMPLE_RATE;
+            playback_channels_    = payload["channels"] | 1;
+            const size_t total_bytes = payload["totalBytes"] | 0;
+            if (total_bytes > 0 && total_bytes < 2 * 1024 * 1024) {
+                playback_samples_.reserve((total_bytes + 1) / 2);
+            }
+            return;
+        }
+        if (std::strcmp(type, "audio.raw") == 0) {
+            handleAudioRaw(payload);
+            return;
+        }
+        if (std::strcmp(type, "audio.end") == 0) {
+            playBufferedAudio();
+            return;
+        }
+        if (std::strcmp(type, "audio.stop") == 0) {
+            playback_samples_.clear();
+            audio_hold_.store(false);
+            sendPlayDone();
+            return;
+        }
+        if (std::strcmp(type, "audio.tone") == 0) {
+            playTone(payload["frequency"] | 880, payload["durationMs"] | 180);
+            return;
+        }
+        if (std::strcmp(type, "audio.volume") == 0) {
+            setOutputVolume(payload["level"] | STACKY_OUTPUT_VOLUME);
+            return;
+        }
+        if (std::strcmp(type, "audio.input_gain") == 0) {
+            setInputGain(payload["level"] | STACKY_MIC_INPUT_GAIN);
+            return;
+        }
+        if (std::strcmp(type, "display.brightness") == 0) {
+            setDisplayBrightness(payload["level"] | display_brightness_.load(), payload["permanent"] | true);
+            return;
+        }
+        if (std::strcmp(type, "vision.capture") == 0) {
+            captureVisionFrame(payload);
+            return;
+        }
+        if (std::strcmp(type, "body.status") == 0) {
+            sendStatus("status");
+            return;
+        }
+        if (std::strcmp(type, "body.motion_config") == 0) {
+            applyMotionConfig(payload);
+            sendStatus("motion_config");
+            return;
+        }
+        if (std::strcmp(type, "body.set_expression") == 0) {
+            const char* expression = payload["name"] | "expression";
+            applyExpression(expression);
+            sendStatus(expression);
+            return;
+        }
+        if (std::strcmp(type, "body.look_at") == 0) {
+            applyLookAt(payload);
+            sendStatus("look_at");
+            return;
+        }
+        if (std::strcmp(type, "body.gesture") == 0) {
+            const char* gesture = payload["name"] | "center";
+            applyGesture(gesture, payload["intensity"] | 1.0f, payload["speed"] | 500);
+            sendStatus(gesture);
+            return;
+        }
+    }
+
+    void handleAudioRaw(JsonVariantConst payload)
+    {
+        const int seq = payload["seq"] | -1;
+        const size_t byte_count = payload["bytes"] | 0;
+        if (byte_count == 0 || (byte_count % 2) != 0 || byte_count > 131072) {
+            sendAudioAck(seq, false);
+            return;
+        }
+
+        const size_t old_samples = playback_samples_.size();
+        playback_samples_.resize(old_samples + byte_count / 2);
+        auto* dest = reinterpret_cast<uint8_t*>(playback_samples_.data() + old_samples);
+        if (!recvExact(dest, byte_count)) {
+            connected_.store(false);
+            return;
+        }
+        sendAudioAck(seq, true);
+    }
+
+    void playTone(int frequency, int duration_ms)
+    {
+        frequency = std::clamp(frequency, 80, 4000);
+        duration_ms = std::clamp(duration_ms, 20, 2000);
+        playback_sample_rate_ = AUDIO_OUTPUT_SAMPLE_RATE;
+        playback_channels_ = 1;
+
+        const size_t sample_count = static_cast<size_t>(AUDIO_OUTPUT_SAMPLE_RATE) * static_cast<size_t>(duration_ms) / 1000;
+        playback_samples_.assign(sample_count, 0);
+        const size_t ramp_samples = std::min<size_t>(240, sample_count / 2);
+        for (size_t i = 0; i < sample_count; ++i) {
+            double gain = 0.22;
+            if (ramp_samples > 0 && i < ramp_samples) {
+                gain *= static_cast<double>(i) / static_cast<double>(ramp_samples);
+            } else if (ramp_samples > 0 && sample_count - i <= ramp_samples) {
+                gain *= static_cast<double>(sample_count - i) / static_cast<double>(ramp_samples);
+            }
+            const double phase = TWO_PI * static_cast<double>(frequency) * static_cast<double>(i) /
+                                 static_cast<double>(AUDIO_OUTPUT_SAMPLE_RATE);
+            playback_samples_[i] = static_cast<int16_t>(std::sin(phase) * 32767.0 * gain);
+        }
+        playBufferedAudio();
+    }
+
+    void playBufferedAudio()
+    {
+        if (playback_samples_.empty()) {
+            sendPlayDone();
+            return;
+        }
+        if (playback_sample_rate_ != AUDIO_OUTPUT_SAMPLE_RATE || playback_channels_ != 1) {
+            ESP_LOGW(TAG, "unsupported playback format sampleRate=%d channels=%d", playback_sample_rate_, playback_channels_);
+            playback_samples_.clear();
+            sendPlayDone();
+            return;
+        }
+
+        playback_active_.store(true);
+        audio_hold_.store(true);
+
+        auto& board = Board::GetInstance();
+        auto* codec = board.GetAudioCodec();
+        if (!codec) {
+            ESP_LOGE(TAG, "audio codec unavailable for playback");
+            playback_samples_.clear();
+            playback_active_.store(false);
+            audio_hold_.store(false);
+            sendPlayDone();
+            return;
+        }
+
+        ESP_LOGI(TAG, "playing %u samples", static_cast<unsigned>(playback_samples_.size()));
+        xSemaphoreTake(audio_mutex_, portMAX_DELAY);
+        if (codec->input_enabled()) {
+            codec->EnableInput(false);
+        }
+        codec->EnableOutput(true);
+        codec->SetOutputVolume(output_volume_.load());
+        showSpeaking(true);
+        std::vector<int16_t> chunk;
+        for (size_t offset = 0; offset < playback_samples_.size() && connected_.load(); offset += PLAYBACK_CHUNK_SAMPLES) {
+            const size_t count = std::min(PLAYBACK_CHUNK_SAMPLES, playback_samples_.size() - offset);
+            chunk.assign(playback_samples_.begin() + offset, playback_samples_.begin() + offset + count);
+            codec->OutputData(chunk);
+        }
+        showSpeaking(false);
+        codec->EnableOutput(false);
+        xSemaphoreGive(audio_mutex_);
+
+        playback_samples_.clear();
+        playback_active_.store(false);
+        audio_hold_.store(false);
+        sendPlayDone();
+    }
+
+    void micTask()
+    {
+        std::vector<int16_t> input;
+        bool input_enabled_by_bridge = false;
+        int warmup_frames_remaining = 0;
+
+        while (true) {
+            if (!enabled_.load() || !connected_.load() || audio_hold_.load() || playback_active_.load()) {
+                if (input_enabled_by_bridge) {
+                    auto* codec = Board::GetInstance().GetAudioCodec();
+                    if (codec) {
+                        xSemaphoreTake(audio_mutex_, portMAX_DELAY);
+                        if (codec->input_enabled()) {
+                            codec->EnableInput(false);
+                        }
+                        xSemaphoreGive(audio_mutex_);
+                    }
+                    input_enabled_by_bridge = false;
+                    warmup_frames_remaining = 0;
+                }
+                vTaskDelay(pdMS_TO_TICKS(20));
+                continue;
+            }
+
+            auto* codec = Board::GetInstance().GetAudioCodec();
+            if (!codec) {
+                vTaskDelay(pdMS_TO_TICKS(200));
+                continue;
+            }
+
+            const int input_channels = std::max(codec->input_channels(), 1);
+            input.resize(MIC_FRAME_COUNT * input_channels);
+
+            xSemaphoreTake(audio_mutex_, portMAX_DELAY);
+            if (!codec->input_enabled()) {
+                codec->SetInputGain(static_cast<float>(input_gain_.load()));
+                codec->EnableInput(true);
+                input_enabled_by_bridge = true;
+                warmup_frames_remaining = MIC_WARMUP_DISCARD_FRAMES;
+            }
+            const bool ok = codec->InputData(input);
+            xSemaphoreGive(audio_mutex_);
+
+            if (!ok) {
+                vTaskDelay(pdMS_TO_TICKS(20));
+                continue;
+            }
+            if (warmup_frames_remaining > 0) {
+                --warmup_frames_remaining;
+                continue;
+            }
+
+            sendAudioIn(input.data(), MIC_FRAME_COUNT, input_channels);
+        }
+    }
+
+    void sendAudioIn(const int16_t* samples, size_t frame_count, int channels)
+    {
+        char header[256];
+        channels = std::max(channels, 1);
+        const size_t byte_count = frame_count * static_cast<size_t>(channels) * sizeof(int16_t);
+        const int len = std::snprintf(
+            header,
+            sizeof(header),
+            "{\"type\":\"audio.in\",\"payload\":{\"encoding\":\"pcm16le\",\"transport\":\"raw\",\"sampleRate\":%d,\"channels\":%d,\"bytes\":%u},\"ts\":%.3f}\n",
+            AUDIO_INPUT_SAMPLE_RATE,
+            channels,
+            static_cast<unsigned>(byte_count),
+            now_seconds());
+        if (len <= 0 || static_cast<size_t>(len) >= sizeof(header)) {
+            return;
+        }
+        if (!send_mutex_) {
+            return;
+        }
+        xSemaphoreTake(send_mutex_, portMAX_DELAY);
+        const bool ok = sendBytesUnlocked(header, static_cast<size_t>(len)) && sendBytesUnlocked(samples, byte_count);
+        xSemaphoreGive(send_mutex_);
+        if (!ok) {
+            connected_.store(false);
+        }
+    }
+
+    void sendAudioAck(int seq, bool queued)
+    {
+        char line[160];
+        const int len = std::snprintf(
+            line,
+            sizeof(line),
+            "{\"type\":\"audio.chunk_ack\",\"payload\":{\"seq\":%d,\"queued\":%s},\"ts\":%.3f}\n",
+            seq,
+            queued ? "true" : "false",
+            now_seconds());
+        if (len > 0 && static_cast<size_t>(len) < sizeof(line)) {
+            sendBytes(line, static_cast<size_t>(len));
+        }
+    }
+
+    void sendPlayDone()
+    {
+        char line[96];
+        const int len = std::snprintf(line, sizeof(line), "{\"type\":\"audio.play_done\",\"payload\":{},\"ts\":%.3f}\n", now_seconds());
+        if (len > 0 && static_cast<size_t>(len) < sizeof(line)) {
+            sendBytes(line, static_cast<size_t>(len));
+        }
+    }
+
+    void sendVisionUnavailable(const char* reason)
+    {
+        char line[192];
+        const int len = std::snprintf(
+            line,
+            sizeof(line),
+            "{\"type\":\"vision.frame\",\"payload\":{\"available\":false,\"reason\":\"%s\"},\"ts\":%.3f}\n",
+            reason,
+            now_seconds());
+        if (len > 0 && static_cast<size_t>(len) < sizeof(line)) {
+            sendBytes(line, static_cast<size_t>(len));
+        }
+    }
+
+    void captureVisionFrame(JsonVariantConst payload)
+    {
+        auto* camera = hal_bridge::board_get_camera();
+        if (!camera) {
+            sendVisionUnavailable("camera_unavailable");
+            return;
+        }
+        if (!camera->StreamCaptures()) {
+            sendVisionUnavailable("camera_capture_failed");
+            return;
+        }
+
+        const uint8_t* frame_data = camera->GetFrameData();
+        const size_t frame_size   = camera->GetFrameSize();
+        const int width           = camera->GetFrameWidth();
+        const int height          = camera->GetFrameHeight();
+        const int format          = camera->GetFrameFormat();
+        const int quality         = std::clamp(payload["quality"] | 20, 5, 80);
+        if (!frame_data || frame_size == 0 || width <= 0 || height <= 0) {
+            sendVisionUnavailable("camera_empty_frame");
+            return;
+        }
+
+        uint8_t* jpeg_data = nullptr;
+        size_t jpeg_size   = 0;
+        const bool encoded = image_to_jpeg(
+            const_cast<uint8_t*>(frame_data),
+            frame_size,
+            width,
+            height,
+            static_cast<v4l2_pix_fmt_t>(format),
+            quality,
+            &jpeg_data,
+            &jpeg_size);
+        if (!encoded || !jpeg_data || jpeg_size == 0) {
+            if (jpeg_data) {
+                free(jpeg_data);
+            }
+            sendVisionUnavailable("jpeg_encode_failed");
+            return;
+        }
+        if (jpeg_size > STACKY_MAX_VISION_JPEG_BYTES) {
+            free(jpeg_data);
+            sendVisionUnavailable("jpeg_too_large");
+            return;
+        }
+
+        std::string jpeg_base64;
+        if (!base64_encode(jpeg_data, jpeg_size, jpeg_base64)) {
+            free(jpeg_data);
+            sendVisionUnavailable("base64_encode_failed");
+            return;
+        }
+        free(jpeg_data);
+
+        std::string line;
+        line.reserve(jpeg_base64.size() + 280);
+        line += "{\"type\":\"vision.frame\",\"payload\":{\"available\":true,\"format\":\"jpeg\",\"encoding\":\"base64\",\"width\":";
+        line += std::to_string(width);
+        line += ",\"height\":";
+        line += std::to_string(height);
+        line += ",\"quality\":";
+        line += std::to_string(quality);
+        line += ",\"bytes\":";
+        line += std::to_string(jpeg_size);
+        line += ",\"sourceFormat\":";
+        line += std::to_string(format);
+        line += ",\"data\":\"";
+        line += jpeg_base64;
+        line += "\"},\"ts\":";
+        line += std::to_string(now_seconds());
+        line += "}\n";
+        if (!sendBytes(line.data(), line.size())) {
+            connected_.store(false);
+        }
+    }
+
+    void setOutputVolume(int level)
+    {
+        level = std::clamp(level, 0, 100);
+        output_volume_.store(level);
+
+        auto* codec = Board::GetInstance().GetAudioCodec();
+        if (codec && audio_mutex_) {
+            xSemaphoreTake(audio_mutex_, portMAX_DELAY);
+            if (codec->output_enabled()) {
+                codec->SetOutputVolume(level);
+            }
+            xSemaphoreGive(audio_mutex_);
+        }
+        sendStatus("volume");
+    }
+
+    void setInputGain(int level)
+    {
+        level = std::clamp(level, 0, 100);
+        input_gain_.store(level);
+
+        auto* codec = Board::GetInstance().GetAudioCodec();
+        if (codec && audio_mutex_) {
+            xSemaphoreTake(audio_mutex_, portMAX_DELAY);
+            if (codec->input_enabled()) {
+                codec->SetInputGain(static_cast<float>(level));
+            }
+            xSemaphoreGive(audio_mutex_);
+        }
+        sendStatus("input_gain");
+    }
+
+    void setDisplayBrightness(int level, bool permanent)
+    {
+        level = std::clamp(level, 1, 100);
+        display_brightness_.store(level);
+        GetHAL().setBackLightBrightness(static_cast<uint8_t>(level), permanent);
+        sendStatus("brightness");
+    }
+
+    void sendStatus(const char* expression)
+    {
+        const auto angles = GetStackChan().motion().getCurrentAngles();
+        auto* codec = Board::GetInstance().GetAudioCodec();
+        const int mic_channels = codec ? std::max(codec->input_channels(), 1) : 1;
+        const int battery_level = std::clamp(static_cast<int>(GetHAL().getBatteryLevel()), 0, 100);
+        const bool battery_charging = GetHAL().isBatteryCharging();
+        const bool camera_available = hal_bridge::board_get_camera() != nullptr;
+        display_brightness_.store(std::clamp(static_cast<int>(GetHAL().getBackLightBrightness()), 1, 100));
+        char line[680];
+        const int len = std::snprintf(
+            line,
+            sizeof(line),
+            "{\"type\":\"status\",\"payload\":{\"device\":\"stackchan-cores3-official\",\"expression\":\"%s\",\"firmware\":\"%s\",\"speakerVolume\":%d,\"micGain\":%.1f,\"displayBrightness\":%d,\"batteryLevel\":%d,\"batteryCharging\":%s,\"micChannels\":%d,\"yaw\":%d,\"pitch\":%d,\"centerYaw\":%d,\"centerPitch\":%d,\"wheelsEnabled\":false,\"cameraAvailable\":%s},\"ts\":%.3f}\n",
+            expression,
+            STACKY_BRIDGE_VERSION,
+            output_volume_.load(),
+            static_cast<float>(input_gain_.load()),
+            display_brightness_.load(),
+            battery_level,
+            battery_charging ? "true" : "false",
+            mic_channels,
+            angles.x,
+            angles.y,
+            center_yaw_.load(),
+            center_pitch_.load(),
+            camera_available ? "true" : "false",
+            now_seconds());
+        if (len > 0 && static_cast<size_t>(len) < sizeof(line)) {
+            sendBytes(line, static_cast<size_t>(len));
+        }
+    }
+
+    void applyLookAt(JsonVariantConst payload)
+    {
+        const float x = std::clamp(payload["x"] | 0.0f, -1.0f, 1.0f);
+        const float y = std::clamp(payload["y"] | 0.0f, -1.0f, 1.0f);
+        const int speed = std::clamp(payload["speed"] | 500, 0, 1000);
+        lookAt(x, y, speed);
+    }
+
+    void applyMotionConfig(JsonVariantConst payload)
+    {
+        center_yaw_.store(std::clamp(payload["centerYaw"] | center_yaw_.load(), -1280, 1280));
+        center_pitch_.store(std::clamp(payload["centerPitch"] | center_pitch_.load(), STACKY_MIN_PITCH, STACKY_MAX_PITCH));
+        look_yaw_range_.store(std::clamp(payload["yawRange"] | look_yaw_range_.load(), 0, 1280));
+        look_up_range_.store(std::clamp(payload["lookUpRange"] | look_up_range_.load(), 0, STACKY_MAX_PITCH));
+        look_down_range_.store(std::clamp(payload["lookDownRange"] | look_down_range_.load(), 0, STACKY_MAX_PITCH));
+    }
+
+    void applyGesture(const char* name, float intensity, int speed)
+    {
+        intensity = std::clamp(intensity, 0.0f, 1.0f);
+        speed     = std::clamp(speed, 0, 1000);
+
+        if (std::strcmp(name, "center") == 0) {
+            moveTo(center_yaw_.load(), center_pitch_.load(), speed);
+            return;
+        }
+        if (std::strcmp(name, "look_left") == 0) {
+            lookAt(-1.0f * intensity, 0.0f, speed);
+            return;
+        }
+        if (std::strcmp(name, "look_right") == 0) {
+            lookAt(1.0f * intensity, 0.0f, speed);
+            return;
+        }
+        if (std::strcmp(name, "look_up") == 0) {
+            lookAt(0.0f, 1.0f * intensity, speed);
+            return;
+        }
+        if (std::strcmp(name, "look_down") == 0) {
+            lookAt(0.0f, -1.0f * intensity, speed);
+            return;
+        }
+        if (std::strcmp(name, "nod") == 0) {
+            lookAt(0.0f, -0.80f * intensity, speed);
+            vTaskDelay(pdMS_TO_TICKS(150));
+            lookAt(0.0f, 0.95f * intensity, speed);
+            vTaskDelay(pdMS_TO_TICKS(150));
+            lookAt(0.0f, 0.0f, speed);
+            return;
+        }
+        if (std::strcmp(name, "shake") == 0) {
+            lookAt(-0.85f * intensity, 0.0f, speed);
+            vTaskDelay(pdMS_TO_TICKS(150));
+            lookAt(0.85f * intensity, 0.0f, speed);
+            vTaskDelay(pdMS_TO_TICKS(150));
+            lookAt(0.0f, 0.0f, speed);
+            return;
+        }
+        moveTo(center_yaw_.load(), center_pitch_.load(), speed);
+    }
+
+    void lookAt(float x, float y, int speed)
+    {
+        const int yaw = center_yaw_.load() + static_cast<int>(std::clamp(x, -1.0f, 1.0f) * look_yaw_range_.load());
+        const int pitch_offset = y >= 0.0f
+                                     ? static_cast<int>(std::clamp(y, 0.0f, 1.0f) * look_up_range_.load())
+                                     : static_cast<int>(std::clamp(y, -1.0f, 0.0f) * look_down_range_.load());
+        const int pitch = std::clamp(center_pitch_.load() + pitch_offset, STACKY_MIN_PITCH, STACKY_MAX_PITCH);
+        moveTo(yaw, pitch, speed);
+    }
+
+    void moveTo(int yaw, int pitch, int speed)
+    {
+        LvglLockGuard lock;
+        auto& motion = GetStackChan().motion();
+        motion.setTorqueEnabled(true);
+        motion.moveWithSpeed(yaw, pitch, std::clamp(speed, 0, 1000));
+    }
+
+    void applyExpression(const char* name)
+    {
+        if (!GetStackChan().hasAvatar()) {
+            return;
+        }
+
+        LvglLockGuard lock;
+        auto& avatar = GetStackChan().avatar();
+        if (std::strcmp(name, "happy") == 0) {
+            avatar.setEmotion(stackchan::avatar::Emotion::Happy);
+            avatar.setSpeech("Stacky");
+        } else if (std::strcmp(name, "thinking") == 0) {
+            avatar.setEmotion(stackchan::avatar::Emotion::Doubt);
+            avatar.setSpeech("taenker");
+        } else if (std::strcmp(name, "listening") == 0) {
+            avatar.setEmotion(stackchan::avatar::Emotion::Neutral);
+            avatar.setSpeech("lytter");
+        } else if (std::strcmp(name, "speaking") == 0) {
+            avatar.setEmotion(stackchan::avatar::Emotion::Happy);
+            avatar.setSpeech("taler");
+        } else {
+            avatar.setEmotion(stackchan::avatar::Emotion::Neutral);
+            avatar.setSpeech("Stacky");
+        }
+    }
+
+    void showSpeaking(bool active)
+    {
+        if (!GetStackChan().hasAvatar()) {
+            return;
+        }
+
+        LvglLockGuard lock;
+        auto& avatar = GetStackChan().avatar();
+        if (active) {
+            avatar.setEmotion(stackchan::avatar::Emotion::Happy);
+            avatar.setSpeech("taler");
+        } else {
+            avatar.setEmotion(stackchan::avatar::Emotion::Neutral);
+            avatar.setSpeech("Stacky");
+        }
+    }
+
+    bool sendBytes(const void* data, size_t size)
+    {
+        if (!send_mutex_) {
+            return false;
+        }
+        xSemaphoreTake(send_mutex_, portMAX_DELAY);
+        const bool ok = sendBytesUnlocked(data, size);
+        xSemaphoreGive(send_mutex_);
+        return ok;
+    }
+
+    bool sendBytesUnlocked(const void* data, size_t size)
+    {
+        bool ok = true;
+        const auto* ptr = static_cast<const uint8_t*>(data);
+        size_t sent_total = 0;
+        while (sent_total < size && socket_ >= 0) {
+            const int sent = send(socket_, ptr + sent_total, size - sent_total, 0);
+            if (sent <= 0) {
+                ok = false;
+                break;
+            }
+            sent_total += static_cast<size_t>(sent);
+        }
+        return ok;
+    }
+
+    void closeSocket()
+    {
+        xSemaphoreTake(send_mutex_, portMAX_DELAY);
+        const int sock = socket_;
+        socket_ = -1;
+        xSemaphoreGive(send_mutex_);
+
+        if (sock >= 0) {
+            shutdown(sock, 0);
+            close(sock);
+        }
+        rx_line_.clear();
+        playback_samples_.clear();
+    }
+};
+
+StackyBridge& GetStackyBridge()
+{
+    static StackyBridgeImpl bridge;
+    return bridge;
+}
