+    void sendI2cScan()
+    {
+        auto i2c_bus = hal_bridge::board_get_i2c_bus();
+        std::string line = "{\"type\":\"i2c.scan\",\"payload\":{\"source\":\"boot-cache\",\"devices\":[";
+        bool first = true;
+        bool proximity_available = false;
+        uint8_t cached_addresses[40] = {};
+        const size_t cached_count = hal_bridge::board_get_i2c_devices(cached_addresses, 40);
+        if (cached_count > 0) {
+            for (size_t index = 0; index < cached_count; ++index) {
+                const int address = cached_addresses[index];
+                if (!first) {
+                    line += ",";
+                }
+                first = false;
+                if (address == 0x29) {
+                    proximity_available = true;
+                }
+                char item[96];
+                std::snprintf(
+                    item,
+                    sizeof(item),
+                    "{\"address\":%d,\"hex\":\"0x%02x\",\"name\":\"%s\"}",
+                    address,
+                    address,
+                    i2c_device_name(address));
+                line += item;
+            }
+        } else if (i2c_bus != nullptr) {
+            line = "{\"type\":\"i2c.scan\",\"payload\":{\"source\":\"runtime-probe\",\"devices\":[";
+            for (int address = 1; address < 128; ++address) {
+                const esp_err_t ret = i2c_master_probe(i2c_bus, static_cast<uint16_t>(address), pdMS_TO_TICKS(45));
+                if (ret != ESP_OK) {
+                    continue;
+                }
+                if (!first) {
+                    line += ",";
+                }
+                first = false;
+                if (address == 0x29) {
+                    proximity_available = true;
+                }
+                char item[96];
+                std::snprintf(
+                    item,
+                    sizeof(item),
+                    "{\"address\":%d,\"hex\":\"0x%02x\",\"name\":\"%s\"}",
+                    address,
+                    address,
+                    i2c_device_name(address));
+                line += item;
+            }
+        }
+        line += "],\"proximityAvailable\":";
+        line += proximity_available ? "true" : "false";
+        line += "},\"ts\":";
+        char ts[32];
+        std::snprintf(ts, sizeof(ts), "%.3f", now_seconds());
+        line += ts;
+        line += "}\n";
+        sendBytes(line.c_str(), line.size());
+    }
