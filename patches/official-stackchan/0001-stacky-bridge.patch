+bool StackChanCamera::SetControl(uint32_t id, int32_t value, uint32_t ctrl_class)
+{
+    if (video_fd_ < 0) return false;
+    struct v4l2_ext_controls ctrls = {};
+    struct v4l2_ext_control ctrl   = {};
+    ctrl.id                        = id;
+    ctrl.value                     = value;
+    ctrls.ctrl_class               = ctrl_class;
+    ctrls.count                    = 1;
+    ctrls.controls                 = &ctrl;
+    if (ioctl(video_fd_, VIDIOC_S_EXT_CTRLS, &ctrls) != 0) {
+        ESP_LOGW(TAG, "set camera control failed id=0x%08lx value=%ld", id, static_cast<long>(value));
+        return false;
+    }
+    return true;
+}
+
+bool StackChanCamera::SetSensorRegister(uint32_t reg, uint32_t value)
+{
+    if (video_fd_ < 0) return false;
+    esp_cam_sensor_reg_val_t reg_value = {};
+    reg_value.regaddr                  = reg;
+    reg_value.value                    = value;
+
+    struct v4l2_ext_controls ctrls = {};
+    struct v4l2_ext_control ctrl   = {};
+    ctrl.id                        = ESP_CAM_SENSOR_IOC_S_REG;
+    ctrl.p_u8                      = reinterpret_cast<uint8_t*>(&reg_value);
+    ctrl.size                      = sizeof(reg_value);
+    ctrls.ctrl_class               = V4L2_CTRL_CLASS_ESP_CAM_IOCTL;
+    ctrls.count                    = 1;
+    ctrls.controls                 = &ctrl;
+    if (ioctl(video_fd_, VIDIOC_S_EXT_CTRLS, &ctrls) != 0) {
+        ESP_LOGW(TAG, "set sensor register failed reg=0x%02lx value=0x%02lx", reg, value);
+        return false;
+    }
+    return true;
+}
+
+bool StackChanCamera::SetAutoExposureLevel(int level)
+{
+    level = std::clamp(level, -2, 2);
+    const uint32_t ae_target = static_cast<uint32_t>(0x48 + (level * 0x08));
+    return SetSensorRegister(GC0308_PAGE_SELECT, 0x00) && SetSensorRegister(GC0308_AEC_TARGET_Y, ae_target);
+}
+
+bool StackChanCamera::SetSensorGain(int gain)
+{
+    gain = std::clamp(gain, 0, 30);
+    const uint32_t gain_value = static_cast<uint32_t>((gain * 63) / 30);
+    return SetSensorRegister(GC0308_PAGE_SELECT, 0x00) && SetSensorRegister(GC0308_GLOBAL_GAIN, gain_value);
+}
+
+bool StackChanCamera::SetSensorExposure(int exposure)
+{
+    exposure = std::clamp(exposure, 0, 1200);
+    const uint32_t exp_high = static_cast<uint32_t>((exposure >> 4) & 0xFF);
+    const uint32_t exp_low = static_cast<uint32_t>((exposure << 4) & 0xF0);
+    return SetSensorRegister(GC0308_PAGE_SELECT, 0x00) &&
+           SetSensorRegister(GC0308_EXPOSURE_HIGH, exp_high) &&
+           SetSensorRegister(GC0308_EXPOSURE_LOW, exp_low);
+}
