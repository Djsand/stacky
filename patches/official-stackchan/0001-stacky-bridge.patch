+    void captureVisionFrame(JsonVariantConst payload)
+    {
+        auto* camera = hal_bridge::board_get_camera();
+        if (!camera) {
+            sendVisionUnavailable("camera_unavailable");
+            return;
+        }
+        const int ae_level = std::clamp(payload["aeLevel"] | 2, -2, 2);
+        const bool ae_ok   = camera->SetAutoExposureLevel(ae_level);
+        bool gain_ok       = true;
+        bool exposure_ok   = true;
+        int sensor_gain    = -1;
+        int sensor_exposure = -1;
+        JsonVariantConst gain_payload = payload["sensorGain"];
+        if (!gain_payload.isNull()) {
+            sensor_gain = std::clamp(gain_payload.as<int>(), 0, 30);
+            gain_ok     = camera->SetSensorGain(sensor_gain);
+        }
+        JsonVariantConst exposure_payload = payload["sensorExposure"];
+        if (!exposure_payload.isNull()) {
+            sensor_exposure = std::clamp(exposure_payload.as<int>(), 0, 1200);
+            exposure_ok     = camera->SetSensorExposure(sensor_exposure);
+        }
+        const int discard_frames = std::clamp(payload["discardFrames"] | 4, 0, 12);
+        const int settle_ms      = std::clamp(payload["settleMs"] | 30, 0, 250);
+        for (int i = 0; i <= discard_frames; ++i) {
+            if (!camera->StreamCaptures()) {
+                sendVisionUnavailable("camera_capture_failed");
+                return;
+            }
+            if (i < discard_frames && settle_ms > 0) {
+                vTaskDelay(pdMS_TO_TICKS(settle_ms));
+            }
+        }
+
+        const uint8_t* frame_data = camera->GetFrameData();
+        const size_t frame_size   = camera->GetFrameSize();
+        const int width           = camera->GetFrameWidth();
+        const int height          = camera->GetFrameHeight();
+        const int format          = camera->GetFrameFormat();
+        const int quality         = std::clamp(payload["quality"] | 50, 5, 80);
+        if (!frame_data || frame_size == 0 || width <= 0 || height <= 0) {
+            sendVisionUnavailable("camera_empty_frame");
+            return;
+        }
+
+        uint8_t* jpeg_data = nullptr;
+        size_t jpeg_size   = 0;
+        const bool encoded = image_to_jpeg(
+            const_cast<uint8_t*>(frame_data),
+            frame_size,
+            width,
+            height,
+            static_cast<v4l2_pix_fmt_t>(format),
+            quality,
+            &jpeg_data,
+            &jpeg_size);
+        if (!encoded || !jpeg_data || jpeg_size == 0) {
+            if (jpeg_data) {
+                free(jpeg_data);
+            }
+            sendVisionUnavailable("jpeg_encode_failed");
+            return;
+        }
+        if (jpeg_size > STACKY_MAX_VISION_JPEG_BYTES) {
+            free(jpeg_data);
+            sendVisionUnavailable("jpeg_too_large");
+            return;
+        }
+
+        std::string jpeg_base64;
+        if (!base64_encode(jpeg_data, jpeg_size, jpeg_base64)) {
+            free(jpeg_data);
+            sendVisionUnavailable("base64_encode_failed");
+            return;
+        }
+        free(jpeg_data);
+
+        std::string line;
+        line.reserve(jpeg_base64.size() + 520);
+        line += "{\"type\":\"vision.frame\",\"payload\":{\"available\":true,\"format\":\"jpeg\",\"encoding\":\"base64\",\"width\":";
+        line += std::to_string(width);
+        line += ",\"height\":";
+        line += std::to_string(height);
+        line += ",\"quality\":";
+        line += std::to_string(quality);
+        line += ",\"bytes\":";
+        line += std::to_string(jpeg_size);
+        line += ",\"sourceFormat\":";
+        line += std::to_string(format);
+        line += ",\"sourceBytes\":";
+        line += std::to_string(frame_size);
+        line += ",\"discardFrames\":";
+        line += std::to_string(discard_frames);
+        line += ",\"settleMs\":";
+        line += std::to_string(settle_ms);
+        line += ",\"aeLevel\":";
+        line += std::to_string(ae_level);
+        line += ",\"aeOk\":";
+        line += ae_ok ? "true" : "false";
+        line += ",\"sensorGain\":";
+        line += std::to_string(sensor_gain);
+        line += ",\"sensorGainOk\":";
+        line += gain_ok ? "true" : "false";
+        line += ",\"sensorExposure\":";
+        line += std::to_string(sensor_exposure);
+        line += ",\"sensorExposureOk\":";
+        line += exposure_ok ? "true" : "false";
+        line += ",\"data\":\"";
+        line += jpeg_base64;
+        line += "\"},\"ts\":";
+        line += std::to_string(now_seconds());
+        line += "}\n";
+        if (!sendBytes(line.data(), line.size())) {
+            connected_.store(false);
+        }
+    }
