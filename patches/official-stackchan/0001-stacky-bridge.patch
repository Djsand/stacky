+    void applyGesture(const char* name, JsonVariantConst payload)
+    {
+        float intensity = payload["intensity"] | 1.0f;
+        int speed       = payload["speed"] | 500;
+        intensity = std::clamp(intensity, 0.0f, 1.0f);
+        speed     = std::clamp(speed, 0, 1000);
+        const bool has_base_x = !payload["baseX"].isNull();
+        const bool has_base_y = !payload["baseY"].isNull();
+        const float base_x    = has_base_x ? std::clamp(payload["baseX"] | 0.0f, -1.0f, 1.0f) : 0.0f;
+        const float base_y    = has_base_y ? std::clamp(payload["baseY"] | 0.0f, -1.0f, 1.0f) : 0.0f;
+        auto x = [&](float offset) {
+            return std::clamp((has_base_x ? base_x : 0.0f) + offset, -1.0f, 1.0f);
+        };
+        auto y = [&](float offset) {
+            return std::clamp((has_base_y ? base_y : 0.0f) + offset, -1.0f, 1.0f);
+        };
+
+        if (std::strcmp(name, "center") == 0) {
+            moveTo(center_yaw_.load(), center_pitch_.load(), speed);
+            return;
+        }
+        if (std::strcmp(name, "look_left") == 0) {
+            lookAt(x(-1.0f * intensity), y(0.0f), speed);
+            return;
+        }
+        if (std::strcmp(name, "look_right") == 0) {
+            lookAt(x(1.0f * intensity), y(0.0f), speed);
+            return;
+        }
+        if (std::strcmp(name, "look_up") == 0) {
+            lookAt(x(0.0f), y(1.0f * intensity), speed);
+            return;
+        }
+        if (std::strcmp(name, "look_down") == 0) {
+            lookAt(x(0.0f), y(-1.0f * intensity), speed);
+            return;
+        }
+        if (std::strcmp(name, "nod") == 0) {
+            const int pause_ms = std::max(220, 430 - speed / 3);
+            lookAt(x(0.0f), y(-0.32f * intensity), speed);
+            vTaskDelay(pdMS_TO_TICKS(pause_ms));
+            lookAt(x(0.0f), y(0.38f * intensity), speed);
+            vTaskDelay(pdMS_TO_TICKS(pause_ms));
+            lookAt(x(0.0f), y(0.0f), std::min(speed, 220));
+            return;
+        }
+        if (std::strcmp(name, "shake") == 0) {
+            const int pause_ms = std::max(220, 430 - speed / 3);
+            lookAt(x(-0.34f * intensity), y(0.0f), speed);
+            vTaskDelay(pdMS_TO_TICKS(pause_ms));
+            lookAt(x(0.34f * intensity), y(0.0f), speed);
+            vTaskDelay(pdMS_TO_TICKS(pause_ms));
+            lookAt(x(0.0f), y(0.0f), std::min(speed, 220));
+            return;
+        }
+        if (std::strcmp(name, "dance") == 0) {
+            const int step_speed = std::min(speed, 210);
+            lookAt(x(-0.18f * intensity), y(0.06f * intensity), step_speed);
+            vTaskDelay(pdMS_TO_TICKS(320));
+            lookAt(x(0.18f * intensity), y(-0.04f * intensity), step_speed);
+            vTaskDelay(pdMS_TO_TICKS(320));
+            lookAt(x(-0.10f * intensity), y(0.08f * intensity), step_speed);
+            vTaskDelay(pdMS_TO_TICKS(320));
+            lookAt(x(0.0f), y(0.0f), step_speed);
+            return;
+        }
+        moveTo(center_yaw_.load(), center_pitch_.load(), speed);
+    }
+
+    void lookAt(float x, float y, int speed)
+    {
+        const int yaw = center_yaw_.load() + static_cast<int>(std::clamp(x, -1.0f, 1.0f) * look_yaw_range_.load());
+        const int pitch_offset = y >= 0.0f
+                                     ? static_cast<int>(std::clamp(y, 0.0f, 1.0f) * look_up_range_.load())
+                                     : static_cast<int>(std::clamp(y, -1.0f, 0.0f) * look_down_range_.load());
+        const int pitch = std::clamp(center_pitch_.load() + pitch_offset, STACKY_MIN_PITCH, STACKY_MAX_PITCH);
+        moveTo(yaw, pitch, speed);
+    }
+
+    void moveTo(int yaw, int pitch, int speed)
+    {
+        LvglLockGuard lock;
+        auto& motion = GetStackChan().motion();
+        motion.setTorqueEnabled(true);
+        motion.moveWithSpeed(yaw, pitch, std::clamp(speed, 0, 1000));
+    }
+
+    void applyExpression(const char* name)
+    {
+        if (!GetStackChan().hasAvatar()) {
+            return;
+        }
+
+        LvglLockGuard lock;
+        auto& avatar = GetStackChan().avatar();
+        if (std::strcmp(name, "happy") == 0) {
+            avatar.setEmotion(stackchan::avatar::Emotion::Happy);
+        } else if (std::strcmp(name, "thinking") == 0) {
+            avatar.setEmotion(stackchan::avatar::Emotion::Doubt);
+        } else if (std::strcmp(name, "listening") == 0) {
+            avatar.setEmotion(stackchan::avatar::Emotion::Neutral);
+        } else if (std::strcmp(name, "speaking") == 0) {
+            avatar.setEmotion(stackchan::avatar::Emotion::Happy);
+        } else if (std::strcmp(name, "error") == 0) {
+            avatar.setEmotion(stackchan::avatar::Emotion::Sad);
+        } else {
+            avatar.setEmotion(stackchan::avatar::Emotion::Neutral);
+        }
+        avatar.setSpeech("");
+    }
+
+    int mouthWeightForAudioChunk(const std::vector<int16_t>& samples)
+    {
+        if (samples.empty()) {
+            return 0;
+        }
+
+        uint64_t sum_squares = 0;
+        int peak = 0;
+        for (int16_t sample : samples) {
+            const int value = static_cast<int>(sample);
+            const int abs_value = std::abs(value);
+            peak = std::max(peak, abs_value);
+            sum_squares += static_cast<uint64_t>(value * value);
+        }
+
+        const double rms = std::sqrt(static_cast<double>(sum_squares) / static_cast<double>(samples.size()));
+        if (peak < 420 || rms < 180.0) {
+            return 0;
+        }
+
+        const int weight = static_cast<int>((rms - 260.0) / 105.0) + 8;
+        return std::clamp(weight, 0, 82);
+    }
+
+    void driveMouthFromAudioChunk(const std::vector<int16_t>& samples)
+    {
+        if (!GetStackChan().hasAvatar()) {
+            return;
+        }
+
+        const int desired = mouthWeightForAudioChunk(samples);
+        int next = 0;
+        if (desired <= 2) {
+            next = 0;
+        } else if (desired > speaking_mouth_weight_) {
+            next = (speaking_mouth_weight_ * 2 + desired * 3) / 5;
+        } else {
+            next = (speaking_mouth_weight_ + desired * 2) / 3;
+        }
+        speaking_mouth_weight_ = std::clamp(next, 0, 82);
+
+        LvglLockGuard lock;
+        auto& avatar = GetStackChan().avatar();
+        avatar.mouth().setWeight(speaking_mouth_weight_);
+        avatar.setSpeech("");
+    }
+
+    void showSpeaking(bool active)
+    {
+        if (!GetStackChan().hasAvatar()) {
+            return;
+        }
+
+        LvglLockGuard lock;
+        auto& avatar = GetStackChan().avatar();
+        if (active) {
+            if (speaking_modifier_id_ >= 0) {
+                GetStackChan().removeModifier(speaking_modifier_id_);
+                speaking_modifier_id_ = -1;
+            }
+            avatar.setEmotion(stackchan::avatar::Emotion::Happy);
+            avatar.setSpeech("");
+            avatar.setModifyLock(true);
+            speaking_mouth_weight_ = 0;
+            avatar.mouth().setWeight(0);
+        } else {
+            if (speaking_modifier_id_ >= 0) {
+                GetStackChan().removeModifier(speaking_modifier_id_);
+                speaking_modifier_id_ = -1;
+            }
+            speaking_mouth_weight_ = 0;
+            avatar.mouth().setWeight(0);
+            avatar.setEmotion(stackchan::avatar::Emotion::Neutral);
+            avatar.setSpeech("");
+            avatar.setModifyLock(false);
+        }
+    }
+
+    void subscribeHeadTouch()
+    {
+        if (head_touch_connection_ >= 0) {
+            return;
+        }
+        head_touch_connection_ = GetHAL().onHeadPetGesture.connect([this](HeadPetGesture gesture) {
+            sendTouchEvent(gesture);
+        });
+    }
+
+    void sendTouchEvent(HeadPetGesture gesture)
+    {
+        if (!connected_.load()) {
+            return;
+        }
+        const char* gesture_name = "unknown";
+        switch (gesture) {
+            case HeadPetGesture::Press:
+                gesture_name = "press";
+                break;
+            case HeadPetGesture::Release:
+                gesture_name = "release";
+                break;
+            case HeadPetGesture::SwipeForward:
+                gesture_name = "swipe_forward";
+                break;
+            case HeadPetGesture::SwipeBackward:
+                gesture_name = "swipe_backward";
+                break;
+            default:
+                return;
+        }
+
+        char line[192];
+        const int len = std::snprintf(
+            line,
+            sizeof(line),
+            "{\"type\":\"touch\",\"payload\":{\"zone\":\"head\",\"gesture\":\"%s\"},\"ts\":%.3f}\n",
+            gesture_name,
+            now_seconds());
+        if (len > 0 && static_cast<size_t>(len) < sizeof(line)) {
+            sendBytes(line, static_cast<size_t>(len));
+        }
+    }
+
+    bool sendBytes(const void* data, size_t size)
+    {
+        if (!send_mutex_) {
+            return false;
+        }
+        xSemaphoreTake(send_mutex_, portMAX_DELAY);
+        const bool ok = sendBytesUnlocked(data, size);
+        xSemaphoreGive(send_mutex_);
+        return ok;
+    }
+
+    bool sendBytesUnlocked(const void* data, size_t size)
+    {
+        bool ok = true;
+        const auto* ptr = static_cast<const uint8_t*>(data);
+        size_t sent_total = 0;
+        while (sent_total < size && socket_ >= 0) {
+            const int sent = send(socket_, ptr + sent_total, size - sent_total, 0);
+            if (sent <= 0) {
+                ok = false;
+                break;
+            }
+            sent_total += static_cast<size_t>(sent);
+        }
+        return ok;
+    }
+
+    void closeSocket()
+    {
+        xSemaphoreTake(send_mutex_, portMAX_DELAY);
+        const int sock = socket_;
+        socket_ = -1;
+        xSemaphoreGive(send_mutex_);
+
+        if (sock >= 0) {
+            shutdown(sock, 0);
+            close(sock);
+        }
+        rx_line_.clear();
+        playback_samples_.clear();
+    }
+};
+
+StackyBridge& GetStackyBridge()
+{
+    static StackyBridgeImpl bridge;
+    return bridge;
+}
