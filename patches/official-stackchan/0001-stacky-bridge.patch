+    void applyLeds(JsonVariantConst payload)
+    {
+        const char* mode = payload["mode"] | "solid";
+        const char* side = payload["side"] | "both";
+        int r = std::clamp(payload["r"] | 0, 0, 255);
+        int g = std::clamp(payload["g"] | 0, 0, 255);
+        int b = std::clamp(payload["b"] | 0, 0, 255);
+        const float brightness = std::clamp(payload["brightness"] | 1.0f, 0.0f, 1.0f);
+        const int duration_ms = std::clamp(payload["durationMs"] | 300, 0, 5000);
+
+        if (std::strcmp(mode, "off") == 0) {
+            r = 0;
+            g = 0;
+            b = 0;
+        } else {
+            r = static_cast<int>(std::round(static_cast<float>(r) * brightness));
+            g = static_cast<int>(std::round(static_cast<float>(g) * brightness));
+            b = static_cast<int>(std::round(static_cast<float>(b) * brightness));
+        }
+
+        led_r_.store(r);
+        led_g_.store(g);
+        led_b_.store(b);
+
+        LvglLockGuard lock;
+        const float duration_sec = static_cast<float>(duration_ms) / 1000.0f;
+        const bool left = std::strcmp(side, "right") != 0;
+        const bool right = std::strcmp(side, "left") != 0;
+        if (left) {
+            GetStackChan().leftNeonLight().setDuration(duration_sec);
+            GetStackChan().leftNeonLight().setColor(r, g, b);
+        }
+        if (right) {
+            GetStackChan().rightNeonLight().setDuration(duration_sec);
+            GetStackChan().rightNeonLight().setColor(r, g, b);
+        }
+    }
